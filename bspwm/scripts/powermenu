#!/bin/sh

shutdown="箚맓  Apagar"
reboot="箚몢  Reiniciar"
suspend="箚쨪  Suspender"
logout="箚뿽  Cerrar sesi처n"

chosen=$(printf "%s\n%s\n%s\n%s" "$shutdown" "$reboot" "$suspend" "$logout" \
    | rofi -dmenu \
           -p "" \
           -theme ~/.config/rofi/themes/powermenu.rasi \
           -no-fixed-num-lines \
           -theme-str 'listview { lines: 4; }')

case "$chosen" in
    "$shutdown")  systemctl poweroff ;;
    "$reboot")    systemctl reboot ;;
    "$suspend")   systemctl suspend ;;
    "$logout")    bspc quit ;;
esac
